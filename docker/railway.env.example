# Railway production env vars — set on the Paperclip app service in the Railway dashboard.
# Do not commit real secrets. See RAILWAY.md and docs/deploy/railway.md.
DATABASE_URL=${{Postgres.DATABASE_URL}}
PAPERCLIP_PUBLIC_URL=https://${{RAILWAY_PUBLIC_DOMAIN}}
BETTER_AUTH_SECRET=<openssl rand -hex 32>
PAPERCLIP_SECRETS_MASTER_KEY=<openssl rand -base64 32>
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_MIGRATION_AUTO_APPLY=true
SERVE_UI=true
HOST=0.0.0.0
HEARTBEAT_SCHEDULER_ENABLED=true
# Memory-first Node runtime (smaller steady-state heap; increase if OOM under load)
# NODE_OPTIONS=--max-old-space-size=512
# PAPERCLIP_NODE_MEMORY_OPTIONS=--max-old-space-size=512
# PAPERCLIP_MEMORY_TELEMETRY_INTERVAL_MS=60000
# Optional adapter keys
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
